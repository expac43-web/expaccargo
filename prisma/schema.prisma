generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  MANAGER
  AGENCY
  CLIENT
}

enum ShipmentStatus {
  PENDING
  PICKED_UP
  CUSTOMS_EXPORT
  IN_TRANSIT
  CUSTOMS_IMPORT
  OUT_DELIVERY
  DELIVERED
  INCIDENT
  CANCELLED
}

enum ServiceType {
  TRANSIT
  MULTIMODAL
  STORAGE
  MARITIME_CONSIGNMENT
  GROUPAGE
}

enum DocumentType {
  INVOICE
  PRO_FORMA
  BILL_OF_LADING
  CUSTOMS_DECL
  CERTIFICATE
  PACKING_LIST
  OTHER
}

enum QuoteStatus {
  NEW
  IN_REVIEW
  QUOTED
  ACCEPTED
  REJECTED
}

enum ConvType {
  CLIENT_AGENCY
  CLIENT_MANAGER
}

model User {
  id               String         @id @default(cuid())
  name             String
  email            String         @unique
  password         String
  phone            String?
  whatsapp         String?
  avatarUrl        String?
  role             Role           @default(CLIENT)
  agencyId         String?
  agency           Agency?        @relation(fields: [agencyId], references: [id])
  shipments        Shipment[]
  sentMessages     Message[]      @relation("SentMessages")
  receivedMessages Message[]      @relation("ReceivedMessages")
  notifications    Notification[]
  documents        Document[]
  clientConvs      Conversation[] @relation("ClientConvs")
  isActive         Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model Agency {
  id        String     @id @default(cuid())
  name      String
  city      String
  country   String
  phone     String?
  email     String?
  users         User[]
  shipments     Shipment[]
  conversations Conversation[]
  createdAt     DateTime       @default(now())
}

model Shipment {
  id             String         @id @default(cuid())
  reference      String         @unique
  trackingNumber String?
  status         ShipmentStatus @default(PENDING)
  serviceType    ServiceType
  origin         String
  destination    String
  weight         Float?
  volume         Float?
  description    String?
  eta            DateTime?
  deliveredAt    DateTime?
  clientId       String
  client         User           @relation(fields: [clientId], references: [id])
  agencyId       String?
  agency         Agency?        @relation(fields: [agencyId], references: [id])
  milestones     Milestone[]
  documents      Document[]
  messages       Message[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model Milestone {
  id         String         @id @default(cuid())
  shipmentId String
  shipment   Shipment       @relation(fields: [shipmentId], references: [id])
  label      String
  location   String?
  status     ShipmentStatus
  occurredAt DateTime       @default(now())
  note       String?
}

model Conversation {
  id        String    @id @default(cuid())
  type      ConvType  @default(CLIENT_AGENCY)
  clientId  String
  client    User      @relation("ClientConvs", fields: [clientId], references: [id])
  agencyId  String?
  agency    Agency?   @relation(fields: [agencyId], references: [id])
  messages  Message[]
  // Suppression « par côté » : le client et le staff (agence/gérant) sont les deux parties.
  // La conversation n'est purgée de la base que lorsque les deux ont supprimé.
  deletedByClient Boolean @default(false)
  deletedByStaff  Boolean @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Message {
  id                String        @id @default(cuid())
  content           String
  senderId          String
  sender            User          @relation("SentMessages", fields: [senderId], references: [id])
  receiverId        String
  receiver          User          @relation("ReceivedMessages", fields: [receiverId], references: [id])
  conversationId    String?
  conversation      Conversation? @relation(fields: [conversationId], references: [id])
  shipmentId        String?
  shipment          Shipment?     @relation(fields: [shipmentId], references: [id])
  isRead            Boolean       @default(false)
  deletedBySender   Boolean       @default(false)
  deletedByReceiver Boolean       @default(false)
  sentAsManager     Boolean       @default(false)
  createdAt         DateTime      @default(now())
}

model Document {
  id           String       @id @default(cuid())
  name         String
  type         DocumentType
  url          String
  shipmentId   String?
  shipment     Shipment?    @relation(fields: [shipmentId], references: [id])
  uploadedById String
  uploadedBy   User         @relation(fields: [uploadedById], references: [id])
  // Auteur réel du dépôt (staff ou client), distinct du propriétaire (uploadedById).
  // Sert au contrôle de suppression. Nullable pour compatibilité historique.
  uploaderId   String?
  createdAt    DateTime     @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  body      String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
}

model QuoteRequest {
  id          String      @id @default(cuid())
  name        String
  email       String
  phone       String
  serviceType ServiceType
  origin      String
  destination String
  cargoType   String
  weight      Float?
  volume      Float?
  notes       String?
  transportMode String?
  preferredDate String?
  dangerous     Boolean   @default(false)
  status      QuoteStatus @default(NEW)
  quotedPrice    Float?
  quotedCurrency String    @default("XAF")
  quoteMessage   String?
  quoteItems     Json?
  quotedAt       DateTime?
  handledById    String?
  handledByName  String?
  handledAt      DateTime?
  createdAt   DateTime    @default(now())
}

model Post {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  excerpt   String
  content   String   @db.Text
  category  String
  lang      String   @default("fr")
  published Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Partner {
  id        String   @id @default(cuid())
  name      String
  logoUrl   String
  website   String?
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

// Jeton de réinitialisation à usage unique (clients : « mot de passe oublié »).
model PasswordResetToken {
  id        String    @id
  userId    String
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([tokenHash])
  @@index([userId])
}

// Historique des actions sur une expédition (qui a modifié quoi). Visible admin/gérant.
model ShipmentAudit {
  id         String   @id @default(cuid())
  shipmentId String
  action     String
  detail     String?
  byId       String?
  byName     String?
  byRole     String?
  createdAt  DateTime @default(now())

  @@index([shipmentId])
}

// Grille tarifaire (gérée par admin/gérant). Sert au calculateur de devis (prix approximatif).
model Tariff {
  id          String   @id
  serviceType String
  origin      String
  destination String
  baseFee          Float    @default(0)
  pricePerKg       Float    @default(0)
  pricePerM3       Float    @default(0)
  volumetricFactor Float    @default(167)
  minPrice         Float    @default(0)
  currency         String   @default("XAF")
  note        String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([isActive])
}

// Liste de suppression (anti-spam) alimentée par les webhooks Resend.
// Toute adresse présente ici n'est plus destinataire d'email (bounce dur / plainte).
model EmailSuppression {
  email     String   @id
  reason    String
  detail    String?
  createdAt DateTime @default(now())
}

// Signature électronique simple (acceptation de devis). Image stockée en bucket privé.
model Signature {
  id          String   @id
  quoteId     String
  userId      String?
  signerName  String
  signerEmail String
  url         String
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([quoteId])
}
